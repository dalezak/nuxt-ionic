{
  "name": "nuxt-ionic",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "reinstall": "rm -rf ./node_modules package-lock.json && npm install && npx nuxi cleanup",
    "update": "npm-check-updates -u",
    "build": "nuxt build",
    "clean": "npx nuxi cleanup",
    "dev": "nuxt dev",
    "local": "nuxt dev --dotenv .env.local",
    "prod": "nuxt dev --dotenv .env.prod",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest run",
    "test:watch": "vitest",
    "types": "npx supabase gen types typescript --project-id tewezjcxrkzpczhwqiju > app/types/database.types.ts"
  },
  "devDependencies": {
    "@nuxt/devtools": "latest",
    "@nuxtjs/device": "^4.0.0",
    "@nuxtjs/ionic": "^1.0.2",
    "@nuxtjs/supabase": "^2.0.5",
    "@snaplet/copycat": "^6.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "nuxt": "^4.4.2",
    "nuxt-viewport": "^2.4.0",
    "sass": "^1.99.0",
    "vitest": "^4.1.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "dependencies": {
    "@capacitor/share": "^8.0.1",
    "@pinia/nuxt": "^0.11.3",
    "@vite-pwa/nuxt": "^1.1.1",
    "idb-keyval": "^6.2.2",
    "ionicons": "^8.0.13",
    "pinia": "^3.0.4",
    "swiper": "^12.1.3",
    "unstorage": "^1.17.5",
    "vue-next-masonry": "^1.1.3"
  }
